using System;
using System.Linq;
using System.Collections.Generic;

namespace Agenda_Escolar;

public class Contacto
{
    private string nombre;
    private string telefono;
    private string correo;

    //Hacemos publica nuestros atributos para su posterior uso
    public string Getnombre()
    {
        return nombre;
    }

    public void setnombre(string nom)
    {
        nombre = nom;
    }

    public string Gettelefono()
    {
        return telefono;
    }

    public void settelefono(string tel)
    {
        telefono = tel;
    }

    public string Getcorreo()
    {
        return correo;
    }

    public void setcorreo(string cor)
    {
        correo = cor;
    }

    //Hacemos sobreescritura de metodos para su posterior uso con las demas clases hijas
    public virtual void Mostrarinformacion()
    {
        Console.WriteLine("Informacion del usuario..");
        Console.WriteLine("El nombre de la persona es: " + nombre);
        Console.WriteLine("El numero de telefono de la persona es: " + telefono);
        Console.WriteLine("El correo de la persona es: " + correo);
    }
}

